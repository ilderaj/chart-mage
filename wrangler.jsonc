{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "chartmage",
  "compatibility_date": "2026-04-29",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "dist"
  },
  "routes": [
    {
      "pattern": "chartmage.paymond.me",
      "custom_domain": true
    }
  ],
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
