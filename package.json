{
  "name": "chartmage",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "serve:app": "python3 -m http.server 8000 --directory app",
    "build": "gulp",
    "build:check": "gulp",
    "pages:deploy": "wrangler pages deploy app --project-name chart-mage --branch main",
    "pages:deploy:preview": "wrangler pages deploy app --project-name chart-mage --branch dev",
    "pages:list": "wrangler pages deployment list --project-name chart-mage",
    "test": "node --test tests/*.test.js",
    "maestro:install": "./scripts/install-maestro.sh",
    "uat:serve": "npm run serve:app",
    "uat:suite": "./scripts/run-maestro-web-smoke.sh",
    "uat:suite:headed": "./scripts/run-maestro-web-smoke.sh --headed",
    "uat:smoke": "npm run uat:suite",
    "uat:smoke:headed": "npm run uat:suite:headed",
    "deploy": "npm run build && wrangler deploy",
    "preview": "npm run build && wrangler dev"
  },
  "author": "Junlin Shang",
  "license": "ISC",
  "devDependencies": {
    "browser-sync": "^3.0.4",
    "cssnano": "^7.1.7",
    "gulp": "^5.0.1",
    "gulp-autoprefixer": "^10.0.0",
    "gulp-if": "^3.0.0",
    "gulp-postcss": "^10.0.0",
    "gulp-uglify": "^3.0.2",
    "gulp-useref": "^5.0.0",
    "wrangler": "^4.86.0"
  }
}
