	flex: 1 1 auto;
	min-width: 0;
	overflow: hidden;
	text-overflow: ellipsis;
	white-space: nowrap;
}

.drawerChartMeta {
	font-size: 11px;
	color: var(--color-text-muted);
	font-feature-settings: "tnum" 1;
}

.drawerTypePill {
	display: inline-flex;
	align-items: center;
	padding: 2px 6px;
	border-radius: 3px;
	font-family: var(--font-mono);
	font-size: 9px;
	font-weight: var(--font-weight-medium);
	letter-spacing: 0.08em;
	text-transform: uppercase;
}

.drawerTypePill.sequence {
	background: rgba(83, 58, 253, 0.12);
	color: var(--color-brand);
}

.drawerTypePill.flowchart {
	background: rgba(234, 34, 97, 0.12);
	color: var(--color-danger);
}

.drawerAction {
	display: inline-flex;
	align-items: center;
	justify-content: center;
	padding: 4px 8px;
	border: 1px solid var(--color-border);
	border-radius: var(--radius-sm);
	background: rgba(255, 255, 255, 0.94);
	font-size: 11px;
	color: var(--color-text-muted);
	visibility: hidden;
}

.drawerAction:hover {
	border-color: var(--color-brand-soft);
	color: var(--color-brand);
	background: var(--color-brand-subtle);
}

.drawerDelete:hover {
	color: var(--color-danger);
	border-color: rgba(234, 34, 97, 0.18);
	background: rgba(234, 34, 97, 0.08);
}

.drawerChart:hover .drawerAction,
.drawerChart.active-row .drawerAction,
.drawerChart.current-chart .drawerAction {
	visibility: visible;
}

.drawerEmpty {
	margin: 10px;
	padding: 18px;
	border: 1px dashed var(--color-brand-soft);
	border-radius: 12px;
	font-size: 14px;
	color: var(--color-text-muted);
	text-align: center;
}

@media (max-width: 1100px) {
	main {
		padding: 12px 12px 14px;
	}

	.workspaceSplit {
		grid-template-columns: minmax(340px, 0.95fr) minmax(380px, 1fr);
	}

	.workspaceDescription {
		max-width: 300px;
	}

	.chart {
		padding-left: 18px;
		padding-right: 18px;
	}

	.chartsDrawer {
		top: var(--app-nav-height);
		right: 12px;
		bottom: 12px;
	}

	.workspaceBackdrop {
		inset: var(--app-nav-height) 0 0 0;
	}
}

.edgeLabel div,
.cluster text,
.node div {
	font-size: 16px;
	line-height: 1.5;
	font-family: var(--font-sans);
	font-feature-settings: var(--font-feature-settings);
}

/* ================================================================
   v3 alignment overrides
   ================================================================ */

html,
body {
	min-width: 0;
}

body {
	background: var(--color-bg);
}

.app-nav {
	position: fixed;
	top: 0;
	left: 0;
	right: 0;
	z-index: 60;
	width: auto;
	height: var(--nav-h);
	min-height: var(--nav-h);
	margin: 0;
	padding: 0 16px;
	border-top: 0;
	border-left: 0;
	border-right: 0;
	border-bottom: 1px solid var(--color-border);
	border-radius: 0;
	background: var(--color-nav-glass);
	box-shadow: none;
	backdrop-filter: blur(14px);
	-webkit-backdrop-filter: blur(14px);
}

.app-layout {
	position: fixed;
	top: var(--nav-h);
	right: 0;
	bottom: 0;
	left: 0;
	display: flex;
	padding: 0;
}

.editor-shell.workspaceFileFrame,
.editor-shell {
	flex: 1 1 auto;
	width: 100%;
	min-height: 0;
	border: 0;
	border-radius: 0;
	background: transparent;
	box-shadow: none;
}

.editor-grid,
.workspaceSplit {
	display: grid;
	grid-template-columns: minmax(0, 1fr) 4px minmax(0, 1fr);
	width: 100%;
	height: 100%;
	min-height: 0;
}

.editor-pane,
.preview-pane,
.workspacePanel {
	min-width: 0;
	min-height: 0;
}

.editor-resizer {
	position: relative;
	background: var(--color-border);
	cursor: col-resize;
}

.editor-resizer::after {
	content: "";
	position: absolute;
	left: 50%;
	top: 50%;
	width: 2px;
	height: 28px;
	transform: translate(-50%, -50%);
	border-radius: 2px;
	background: var(--color-border-strong);
}

.editor,
.editor-pane {
	border-right: 0;
	background: var(--color-editor-bg);
}

.diagram,
.preview-pane {
	background: var(--color-canvas-bg);
}

.workspaceHeader {
	padding: 0 14px;
	height: 44px;
}

.workspaceBody {
	padding: 0;
}

.editorBody {
	display: flex;
	flex-direction: column;
}

.quickInsertBar {
	padding: 12px 14px;
	border-bottom: 1px solid var(--color-border);
	background: var(--color-surface);
}

.previewBody {
	display: flex;
	flex-direction: column;
	gap: 0;
	background-image: radial-gradient(var(--color-canvas-grid) 1px, transparent 1px);
	background-size: 20px 20px;
}

.chart {
	min-height: 0;
	padding: 24px;
	background: transparent;
}

#graphDiv {
	max-height: none;
}

.workspaceBackdrop,
.modal-overlay {
	position: fixed;
	inset: var(--nav-h) 0 0 0;
	background: var(--color-overlay-soft);
	backdrop-filter: blur(4px);
	z-index: 45;
	opacity: 0;
	pointer-events: none;
	transition: opacity var(--transition-base);
}

.modal-overlay.open,
.workspaceBackdrop:not(.hidden) {
	opacity: 1;
	pointer-events: auto;
}

.chartsDrawer,
.drawer {
	position: fixed;
	top: var(--nav-h);
	right: 0;
	bottom: 0;
	width: min(360px, 92vw);
	border-top: 0;
	border-right: 0;
	border-bottom: 0;
	border-left: 1px solid var(--color-border);
	border-radius: 0;
	background: rgba(255, 255, 255, 0.98);
	box-shadow: var(--shadow-deep);
	transform: translateX(100%);
	transition: transform 220ms cubic-bezier(.16,1,.3,1);
}

.drawer.open,
.chartsDrawer:not(.hidden) {
	transform: translateX(0);
}

.drawerMeta {
	display: inline-flex;
	align-items: center;
	align-self: flex-start;
	padding: 5px 10px;
	border-radius: 999px;
	background: var(--color-brand-subtle);
	border-bottom: 0;
	letter-spacing: 0.06em;
	text-transform: none;
}

.mobile-gate {
	display: none;
	position: fixed;
	inset: 0;
	z-index: 70;
	align-items: center;
	justify-content: center;
	flex-direction: column;
	padding: 32px 20px;
	background: var(--color-surface);
	text-align: center;
}

.mobile-gate-logo {
	margin-bottom: 24px;
}

.mobile-gate h2 {
	margin: 0 0 12px;
	font-size: 24px;
	font-weight: var(--font-weight-light);
	letter-spacing: -0.02em;
	color: var(--color-heading);
}

.mobile-gate p {
	max-width: 320px;
	margin: 0 0 20px;
	font-size: 14px;
	line-height: 1.6;
	color: var(--color-text);
}

@media (max-width: 1100px) {
	.editor-grid,
	.workspaceSplit {
		grid-template-columns: minmax(0, 1fr) 4px minmax(0, 1fr);
	}
}

@media (max-width: 767px) {
	.mobile-gate {
		display: flex;
	}

	.app-layout,
	.app-nav {
		display: none;
	}
}
