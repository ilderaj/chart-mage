	justify-content: center;
	gap: 6px;
	min-height: 34px;
	padding: 0 9px;
	flex-shrink: 0;
	border: 1px solid var(--color-border-strong);
	border-radius: 6px;
	background: rgba(255, 255, 255, 0.9);
