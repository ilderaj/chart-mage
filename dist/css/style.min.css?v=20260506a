}

.new-chart-picker-tag {
	display: inline-flex;
	align-items: center;
	justify-content: center;
	padding: 2px 8px;
	border-radius: 999px;
	background: var(--color-brand-subtle);
	color: var(--color-brand);
	font-family: var(--font-mono);
	font-size: 10px;
	font-weight: var(--font-weight-medium);
	letter-spacing: 0.08em;
	text-transform: uppercase;
}

@media (max-width: 1120px) {
	.app-nav {
		width: calc(100% - 16px);
		padding: 7px 8px;
		gap: 6px;
	}

	.app-nav-left {
		gap: 6px;
	}

	.nav-divider {
		display: none;
	}

	.nav-brand-logo {
		gap: 7px;
		font-size: 15px;
	}

	.nav-brand-logo .brand-mark {
		width: 24px;
		height: 24px;
		border-radius: 6px;
	}

	.nav-chart-pill {
		max-width: 160px;
	}

	.nav-chart-pill-name {
		max-width: 92px;
	}

	.app-nav-search {
		width: 124px;
		min-width: 124px;
		max-width: 124px;
		flex: 0 0 124px;
	}

	.app-nav-search input {
		padding-right: 14px;
	}

	.app-nav-search kbd {
		display: none;
	}

	.app-nav-actions {
		gap: 3px;
	}

	.nav-button {
		min-height: 32px;
		padding: 0 8px;
		gap: 5px;
		font-size: 11px;
	}

	.save-pill {
		gap: 5px;
		font-size: 10px;
	}
